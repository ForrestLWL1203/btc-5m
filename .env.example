# Polymarket Trading Bot — Environment Variables
# Copy this file to .env and fill in values (or leave empty to auto-load from polymarket CLI config)

# Private key (overrides CLI config if set)
# PK=0x...

# Funder address (EOA that holds funds, used with proxy signature type)
# FUNDER=0x...

# API Credentials (optional, for L2 auth)
# CLOB_API_KEY=
# CLOB_SECRET=
# CLOB_PASS_PHRASE=

# CLOB API URL (defaults to https://clob.polymarket.com)
# CLOB_API_URL=https://clob.polymarket.com

# Chain ID (defaults to 137 = Polygon mainnet)
# CHAIN_ID=137
