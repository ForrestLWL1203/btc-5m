# Polymarket Trading Bot Configuration
# Copy to strategy.yaml and customize

# Market selection (supported: btc/eth × 5m/15m/4h)
market:
  asset: btc              # btc or eth
  timeframe: 5m           # 5m, 15m, or 4h

# Round control (top-level, applies to all strategies)
# rounds: 1               # Number of complete windows to run (omit or null for infinite)

# Strategy — handles both direction and buy decision
strategy:
  type: immediate         # immediate = fixed side, buy at window open price
  side: up                # "up" or "down" (only for immediate strategy)

# For auto direction prediction, use:
# strategy:
#   type: momentum         # auto-predict direction using momentum signals

# Common trading parameters (apply to all strategies)
params:
  amount: 5.0             # USD per trade

  # TP/SL — percentage-based or absolute price (absolute takes priority if both set)
  # Percentage mode (default):
  tp_pct: 0.50            # +50% from entry price → sell at entry * 1.50
  sl_pct: 0.30            # -30% from entry price → sell at entry * 0.70

  # Absolute price mode (uncomment to use):
  # tp_price: 0.80         # sell when price reaches $0.80
  # sl_price: 0.35         # sell when price drops to $0.35

  # Mixed mode (absolute TP + percentage SL, etc.) also supported

  max_sl_reentry: 0       # max re-buys after stop-loss (0 = no re-entry)
  max_tp_reentry: 0       # max re-buys after take-profit (0 = no re-entry)
